    <script>
        (function() {
            const page1 = document.getElementById('page1');
            const page2 = document.getElementById('page2');
            const page3 = document.getElementById('page3');
            const navBtns = document.querySelectorAll('.page-nav .page-btn');

            function showPage(pageId) {
                page1.classList.add('hidden');
                page2.classList.add('hidden');
                page3.classList.add('hidden');
                
                let targetPage = null;
                if (pageId === '1') targetPage = page1;
                if (pageId === '2') targetPage = page2;
                if (pageId === '3') targetPage = page3;

                if (targetPage) {
                    targetPage.classList.remove('hidden');
                    setTimeout(() => {
                        targetPage.scrollIntoView({ 
                            behavior: 'smooth', 
                            block: 'start' 
                        });
                    }, 40);
                }

                navBtns.forEach(btn => {
                    btn.classList.toggle('active', btn.dataset.page === pageId);
                });

                setTimeout(() => {
                    if (typeof window.updateDotsFromScroll === 'function') {
                        window.updateDotsFromScroll();
                    }
                }, 350);
            }

            navBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    showPage(this.dataset.page);
                });
            });

            page1.classList.remove('hidden');
            page2.classList.add('hidden');
            page3.classList.add('hidden');
        })();

        (function() {
            const scrollContainer = document.getElementById('flowScroll');
            const prevBtn = document.getElementById('flowPrev');
            const nextBtn = document.getElementById('flowNext');
            const dotsContainer = document.getElementById('flowDots');
            const items = scrollContainer.querySelectorAll('.flow-item');
            const totalItems = items.length;

            dotsContainer.innerHTML = '';
            for (let i = 0; i < totalItems; i++) {
                const dot = document.createElement('button');
                dot.className = 'flow-dot' + (i === 0 ? ' active' : '');
                dot.setAttribute('data-index', i);
                dot.addEventListener('click', function() {
                    const index = parseInt(this.getAttribute('data-index'));
                    items[index].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });
                    updateDots(index);
                });
                dotsContainer.appendChild(dot);
            }

            const dots = dotsContainer.querySelectorAll('.flow-dot');
            function updateDots(activeIndex) {
                dots.forEach((dot, i) => { dot.classList.toggle('active', i === activeIndex); });
            }

            window.updateDotsFromScroll = function() {
                const scrollLeft = scrollContainer.scrollLeft;
                const containerWidth = scrollContainer.clientWidth;
                let minDist = Infinity;
                let closestIndex = 0;
                items.forEach((item, i) => {
                    const itemLeft = item.offsetLeft - scrollContainer.offsetLeft;
                    const center = itemLeft + item.offsetWidth / 2;
                    const viewCenter = scrollLeft + containerWidth / 2;
                    const dist = Math.abs(center - viewCenter);
                    if (dist < minDist) { minDist = dist; closestIndex = i; }
                });
                updateDots(closestIndex);
            };

            scrollContainer.addEventListener('scroll', window.updateDotsFromScroll);
            prevBtn.addEventListener('click', () => { scrollContainer.scrollBy({ left: -scrollContainer.clientWidth * 0.8, behavior: 'smooth' }); });
            nextBtn.addEventListener('click', () => { scrollContainer.scrollBy({ left: scrollContainer.clientWidth * 0.8, behavior: 'smooth' }); });
        })();
    </script>
    <script src="assets/js/background.js"></script>
</body>
</html>
