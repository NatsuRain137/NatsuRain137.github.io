<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HebutMC</title>
    <link rel="icon" href="favicon.ico" />
    <link rel="stylesheet" href="assets/css/index.css" />
    <link rel="stylesheet" href="assets/css/font.css" />
    <style>
        /* ===== 0. 全局纯直角规范 ===== */
        * {
            border-radius: 0 !important;
        }

        body {
            font-family: 'Consolas', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 0;
            background: #f4f6f9; 
            color: #102a43; 
        }

        /* 🔥 核心修改：去掉白色图层遮罩，背景图 100% 完全显现 */
        img[background] {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            object-fit: cover;
            z-index: -1;
            opacity: 1 !important; /* 移除白蒙版，完全不透明 */
            filter: none !important;  /* 移除灰度滤镜，展现原本色彩 */
            pointer-events: none;
        }

        header, section, footer, .gotop {
            position: relative;
            z-index: 5;
        }

        /* ===== 1. 顶部栏：低饱和蓝灰纯色块 + 毛玻璃 ===== */
        header[topbar] {
            background: rgba(240, 244, 248, 0.8) !important;
            backdrop-filter: blur(16px) !important;
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 3px solid #1d3557 !important; 
            box-shadow: 0 4px 30px rgba(16, 42, 67, 0.04) !important;
        }

        header[topbar] p[title], header[topbar] p[everypoem] {
            color: #1d3557 !important;
            font-weight: 700;
        }

        section[firstpage] p[title] {
            color: #1d3557 !important;
            text-shadow: 0 2px 10px rgba(255, 255, 255, 0.8);
        }

        /* 介绍区域：在清晰背景上表现出高斯折射 */
        section.secondpage .leftside {
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(16px) !important;
            -webkit-backdrop-filter: blur(16px);
            border: none !important; 
            box-shadow: 12px 12px 0px rgba(16, 42, 67, 0.15); 
        }
        section.secondpage .leftside p[title] { color: #102a43 !important; }
        section.secondpage .leftside p[text] { color: #334e68 !important; }

        /* ===== 2. 第三页：地图容器 ===== */
        .embed-wrapper {
            position: relative;
            width: 100%;
            max-width: 1280px;
            margin: 30px auto 40px;
            padding: 0 16px;
            box-sizing: border-box;
            z-index: 20;
        }

        .embed-container {
            position: relative;
            width: 100%;
            height: 0;
            padding-bottom: 56.25%;
            overflow: hidden;
            background: #d9e2ec; 
            border: none; 
            box-shadow: 16px 16px 0px rgba(16, 42, 67, 0.15);
        }

        .embed-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
            background: #ffffff;
        }

        /* ===== 3. 第二页：Flow 横向卡片流 ===== */
        .flow-wrapper {
            position: relative;
            width: 100%;
            max-width: 1280px;
            margin: 20px auto 40px;
            padding: 0 16px;
            box-sizing: border-box;
            z-index: 20;
        }

        .flow-container {
            position: relative;
            width: 100%;
            overflow: hidden;
            background: rgba(234, 241, 247, 0.65) !important; 
            backdrop-filter: blur(20px) !important;
            -webkit-backdrop-filter: blur(20px);
            border: none;
            box-shadow: 16px 16px 0px rgba(16, 42, 67, 0.15);
        }

        .flow-scroll {
            display: flex;
            overflow-x: auto;
            overflow-y: hidden;
            scroll-snap-type: x mandatory;
            padding: 24px;
            gap: 20px;
            min-height: 360px;
            scrollbar-width: thin;
            scrollbar-color: #9fb3c8 transparent;
        }

        .flow-scroll::-webkit-scrollbar { height: 6px; }
        .flow-scroll::-webkit-scrollbar-thumb { background: #9fb3c8; }

        .flow-item {
            flex: 0 0 320px;
            scroll-snap-align: start;
            background: rgba(255, 255, 255, 0.95);
            padding: 24px;
            border: none; 
            transition: all 0.2s ease;
            display: flex;
            flex-direction: column;
            min-height: 320px;
            box-sizing: border-box;
            box-shadow: 4px 4px 12px rgba(16, 42, 67, 0.04);
        }

        .flow-item:hover {
            transform: translateY(-4px);
            background: #ffffff;
            box-shadow: 12px 12px 0px rgba(16, 42, 67, 0.12);
        }

        .flow-item .item-label {
            display: inline-block;
            background: #102a43;
            padding: 4px 12px;
            font-size: 11px;
            color: #ffffff;
            font-weight: 600;
            letter-spacing: 1px;
            margin-bottom: 16px;
            align-self: flex-start;
        }

        .flow-item .real-content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .flow-item .real-content .title {
            font-size: 20px;
            font-weight: 700;
            color: #102a43;
            margin-bottom: 16px;
        }

        .flow-item .real-content .desc {
            font-size: 14px;
            line-height: 1.6;
            flex: 1;
        }

        .flow-item .real-content .media-placeholder {
            width: 100%;
            aspect-ratio: 16/9;
            background: #d9e2ec; 
            border: none; 
            display: flex;
            align-items: center;
            justify-content: center;
            color: #486581; 
            font-size: 13px;
            font-weight: 600;
            flex-direction: column;
            gap: 6px;
            margin-top: 8px;
        }
        
        .flow-item:hover .media-placeholder {
            background: #bcccdc; 
        }

        .text-line {
            height: 12px;
            margin-bottom: 10px;
            width: 100%;
        }
        .text-line:nth-child(1) { background: #9fb3c8; width: 90%; } 
        .text-line:nth-child(2) { background: #bcdcdc; width: 75%; } 
        .text-line:nth-child(3) { background: #d9e2ec; width: 55%; } 

        .flow-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            padding: 16px 0;
            background: rgba(255, 255, 255, 0.6);
            position: relative;
            z-index: 25;
        }

        .flow-dot {
            width: 16px;
            height: 4px;
            background: #bcdcdc; 
            cursor: pointer;
            transition: all 0.2s ease;
            border: none;
            padding: 0;
        }

        .flow-dot.active {
            background: #f97316; 
            width: 32px;
        }

        .flow-nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: #ffffff;
            border: none;
            color: #102a43;
            width: 40px;
            height: 40px;
            cursor: pointer;
            font-size: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 30;
            transition: all 0.15s ease;
            box-shadow: 2px 2px 6px rgba(0,0,0,0.1);
        }

        .flow-nav-btn:hover {
            background: #f97316; 
            color: #ffffff;
        }

        .flow-nav-btn.prev { left: 0; }
        .flow-nav-btn.next { right: 0; }

        /* ===== 4. 右侧固定直角导航栏 ===== */
        .page-nav-wrapper {
            position: fixed;
            right: 24px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 100;
            display: flex;
            justify-content: center;
            pointer-events: none;
        }

        .page-nav-wrapper .page-nav { pointer-events: auto; }

        .page-nav {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 2px;
            margin: 0;
            padding: 4px;
            background: rgba(255, 255, 255, 0.85) !important;
            backdrop-filter: blur(12px) !important;
            -webkit-backdrop-filter: blur(12px);
            border: none;
            box-shadow: 8px 8px 0px rgba(16, 42, 67, 0.15);
        }

        .page-nav .page-btn {
            background: transparent;
            border: none;
            color: #486581;
            font-size: 13px;
            padding: 10px 18px;
            cursor: pointer;
            transition: all 0.15s ease;
            font-weight: 600;
            white-space: nowrap;
        }

        .page-nav .page-btn:hover {
            color: #f97316;
            background: #ffedd5; 
        }

        .page-nav .page-btn.active {
            color: #ffffff !important;
            background: #f97316 !important;
            font-weight: 700;
        }

        .page-container {
            display: block;
            width: 100%;
            scroll-margin-top: 100px;
        }

        .page-container.hidden { display: none; }

        /* ===== 5. 🔥 页脚系统：全面重构为深色体系 ===== */
        footer[bottombar] {
            background: #102a43 !important; /* 深工业蓝 */
            border-top: 4px solid #f97316 !important; /* 强力橙色撞色切线 */
            padding: 60px 40px !important;
            color: #ffffff !important;
        }

        footer[bottombar] p[title] {
            color: #ffffff !important;
            font-weight: 700;
        }

        footer[bottombar] p, footer[bottombar] a { 
            color: #bcccdc !important; /* 调整为高可读性的浅蓝灰字 */
            text-shadow: none; 
        }
        
        footer[bottombar] a:hover { 
            color: #f97316 !important; /* 悬浮撞橙 */
        }

        footer[copyright] {
            background: #091e36 !important; /* 最底层：极深工业夜空蓝 */
            border: none !important;
            padding: 20px !important;
        }
        footer[copyright] p { 
            color: #627d98 !important; 
        }
        footer[copyright] p a {
            color: #bcccdc !important;
            text-decoration: none;
        }
        footer[copyright] p a:hover {
            color: #f97316 !important;
        }

        .gotop div {
            background: #ffffff !important;
            border: none !important;
            color: #102a43 !important;
            box-shadow: 4px 4px 0px rgba(16, 42, 67, 0.2);
        }
        .gotop div:hover {
            background: #f97316 !important;
            color: #ffffff !important;
        }

        @media (max-width: 768px) {
            .embed-wrapper { padding: 0 8px; margin: 20px auto 30px; }
            .flow-item { flex: 0 0 280px; padding: 16px; min-height: 280px; }
            .flow-scroll { padding: 16px 12px; gap: 12px; min-height: 300px; }
            .flow-nav-btn { width: 36px; height: 36px; }
            .page-nav-wrapper { right: 8px; }
            .page-nav .page-btn { font-size: 12px; padding: 8px 12px; }
        }
    </style>
</head>
